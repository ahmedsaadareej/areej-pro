router.get('/marketplace/admin/quotes', requireAuth, (req, res) => {
  if (req.user.role !== 'admin') return res.status(403).json({ ok: false });
  try {
    const rows = masterForMarket.prepare('SELECT q.*, s.name as supplier_name, s.commission_rate FROM marketplace_quotes q JOIN marketplace_suppliers s ON s.id=q.supplier_id ORDER BY q.created_at DESC LIMIT 50').all();
    const total_deals = masterForMarket.prepare('SELECT SUM(deal_amount) as t FROM marketplace_quotes WHERE deal_amount > 0').get().t || 0;
    const total_commission = masterForMarket.prepare('SELECT SUM(commission_amount) as t FROM marketplace_quotes WHERE commission_amount > 0').get().t || 0;
    res.json({ ok: true, quotes: rows, total_deals, total_commission });
  } catch(e) { res.json({ ok: false, error: e.message }); }
});

router.put('/marketplace/admin/quotes/:id', requireAuth, (req, res) => {
  if (req.user.role !== 'admin') return res.status(403).json({ ok: false });
  try {
    const { status, deal_amount } = req.body;
    const q = masterForMarket.prepare('SELECT * FROM marketplace_quotes q JOIN marketplace_suppliers s ON s.id=q.supplier_id WHERE q.id=?').get(req.params.id);
    if (!q) return res.json({ ok: false, error: 'not found' });
    const commission = deal_amount ? (deal_amount * (q.commission_rate / 100)) : 0;
    masterForMarket.prepare('UPDATE marketplace_quotes SET status=?, deal_amount=?, commission_amount=? WHERE id=?').run(status || q.status, deal_amount || q.deal_amount, commission, req.params.id);
    res.json({ ok: true });
  } catch(e) { res.json({ ok: false, error: e.message }); }
});

