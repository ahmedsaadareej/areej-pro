router.post('/inbox/broadcasts', requireAuth, async (req, res) => {
  const db = req.db;
  try {
    const { title: rawTitle, name: rawName, message, platform, audience, scheduled_at } = req.body;
    const title = rawTitle || rawName;
    if (!title || !message) return res.json({ ok: false, error: 'title and message required' });
    // audience: 'all' | 'clients' | 'vip' | custom array of contact_ids
    const r = db.prepare('INSERT INTO inbox_broadcasts (title, message, platform, audience, status, scheduled_at) VALUES (?,?,?,?,?,?)')
      .run(title, message, platform||'telegram', JSON.stringify(audience||'all'), 'draft', scheduled_at||null);
    res.json({ ok: true, id: r.lastInsertRowid });
  } catch(e) { res.json({ ok: false, error: e.message }); }
});

router.post('/inbox/broadcasts/:id/send', requireAuth, async (req, res) => {
  const db = req.db;
  try {
    const broadcast = db.prepare('SELECT * FROM inbox_broadcasts WHERE id=?').get(req.params.id);
    if (!broadcast) return res.json({ ok: false, error: 'not found' });
    const settings = db.prepare('SELECT * FROM inbox_settings WHERE id=1').get();
    if (!settings || !settings.telegram_token) return res.json({ ok: false, error: 'تيليجرام غير مفعّل' });
    // Get audience conversations
    let conversations = db.prepare("SELECT * FROM inbox_conversations WHERE platform='telegram'").all();
    if (broadcast.audience !== 'all' && broadcast.audience !== '"all"') {
      try {
        const aud = JSON.parse(broadcast.audience);
        if (Array.isArray(aud)) conversations = conversations.filter(c => aud.includes(c.id));
      } catch(e) {}
    }
    let sent = 0; let failed = 0;
    const https = require('https');
    for (const conv of conversations) {
      try {
        await new Promise((resolve) => {
          const payload = JSON.stringify({ chat_id: conv.sender_id, text: broadcast.message });
          const req2 = https.request({
            hostname: 'api.telegram.org', path: '/bot'+settings.telegram_token+'/sendMessage',
            method: 'POST', headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(payload) }
          }, (r2) => { r2.on('data',()=>{}); r2.on('end', resolve); });
          req2.on('error', () => { failed++; resolve(); });
          req2.write(payload); req2.end();
        });
        sent++;
      } catch(e) { failed++; }
    }
    db.prepare('UPDATE inbox_broadcasts SET status=?, sent_count=?, failed_count=?, sent_at=datetime(\'now\') WHERE id=?')
      .run('sent', sent, failed, broadcast.id);
    res.json({ ok: true, sent, failed, total: conversations.length });
  } catch(e) { res.json({ ok: false, error: e.message }); }
});

