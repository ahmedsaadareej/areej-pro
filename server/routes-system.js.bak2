    const r = masterForMarket.prepare('INSERT INTO marketplace_suppliers (name,phone,products,regions,price_range,description,commission_rate,status) VALUES (?,?,?,?,?,?,?,?)').run(name,phone,products,regions||'',price_range||'',description||'',commission_rate||3,'approved');
