      VALUES (1,?,?,?,?,?,?,?,datetime('now'))`).run(bosta_api_key||'', aramex_api_key||'', jnt_api_key||'', default_company||'bosta', sender_name||'', sender_phone||'', sender_address||'');
    res.json({ ok: true });
  } catch(e) { res.json({ ok: false, error: e.message }); }
